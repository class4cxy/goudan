# ── LLM ──────────────────────────────────────────────────────────
# 主模型（chat/task 等主链路）：DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key

# ── Roborock ──────────────────────────────────────────────────────
# 推荐：运行 `python platform/login_once.py` 完成一次性验证码登录
#       生成 platform/.roborock_token.json 后，Platform 启动不再需要密码
#
# 备用（次选）：密码登录（密码会以明文发到 Roborock 服务器，有日志记录风险）
ROBOROCK_USERNAME=your_xiaomi_email
# ROBOROCK_PASSWORD=your_xiaomi_password  ← 使用 token 文件后可删除此行

# Roborock 区域（cn=中国大陆，eu=欧洲，us=美国，默认 cn）
ROBOROCK_REGION=cn

# ── Platform 服务地址 ─────────────────────────────────────────────
# Platform HTTP 地址（REST API，默认本地；树莓派远程调试改为 http://192.168.x.x:8001）
PLATFORM_URL=http://localhost:8001

# Platform WebSocket 地址（实时事件双向通道）
PLATFORM_WS_URL=ws://localhost:8001/ws

# 语音对话是否必须唤醒词。调试链路时可设 false（免唤醒）
VOICE_REQUIRE_WAKE_WORD=true

# 语音转文字配置
# 配置了本地就用本地，配置了远端就用远端，用不了直接报错（无自动降级）
#
# 【本地 STT】支持两种后端（LOCAL_STT_BACKEND 切换）
# LOCAL_STT_BACKEND=whisper     # 默认：faster-whisper，轻量开箱即用
# LOCAL_STT_BACKEND=qwen        # 备选：antirez/qwen-asr 纯 C，精度更高（需 8GB RAM）
#
# whisper 后端：pip install faster-whisper
# LOCAL_STT_MODEL=base          # tiny(39MB)/base(74MB)/small(244MB)
# LOCAL_STT_DEVICE=cpu
# LOCAL_STT_COMPUTE=int8
#
# qwen 后端：编译 antirez/qwen-asr + 下载模型
# LOCAL_STT_QWEN_BIN=~/qwen-asr/qwen_asr
# LOCAL_STT_QWEN_MODEL=~/qwen-asr/qwen3-asr-0.6b
#
# LOCAL_STT_URL=                # 显式指定本地 STT 端点（platform 已移除 /stt，默认用云端）
# STT_USE_CLOUD=1               # 设为 1 时强制使用云端 ASR

# 【云端 ASR】Qwen ASR（默认使用，需配置 SPEECH_API_URL / SPEECH_API_KEY）
SPEECH_API_URL=
SPEECH_API_KEY=

# 麦克风人声门控（Python 侧）
# MIC_MIN_VOICED_RATIO=0.35
# MIC_MIN_CLIP_RMS_DBFS=-42
# MIC_MUTE_TIMEOUT_S=25   # mute 超时（秒），超时强制 unmute 防止录音休眠
# MIC_MAX_SPEECH_MS=9000
# MIC_MIN_VOICE_BAND_RATIO=0.52
# MIC_MIN_ZCR=0.01
# MIC_MAX_ZCR=0.22

# ── 扬声器 / 蓝牙音频（Chat 模式）────────────────────────────────
#
# Chat 模式架构：手机端录音 → STT → 文字发给机器人 → TTS 回复通过蓝牙外放
# 不使用麦克风，无回声问题，录音全权交给手机处理。
#
# 播放后端选择：
#   alsa（默认）  — aplay，适合 USB 声卡直连
#   pulseaudio    — pacat，通过 PipeWire/PulseAudio A2DP 路由，蓝牙外放必须选此项
#
# 树莓派 5 蓝牙外放时，设置为 pulseaudio：
SPEAKER_BACKEND=pulseaudio
#
# 已连接蓝牙音响的 MAC 地址（供 connect_speaker.py 脚本读取，可省略手动输入）
# 首次使用先运行：python3 platform/connect_speaker.py --scan
# SPEAKER_MAC=AA:BB:CC:DD:EE:FF
#
# ALSA 后端专用：指定 aplay 输出设备（SPEAKER_BACKEND=alsa 时生效，默认 "default"）
# SPEAKER_ALSA_DEVICE=default
#
# TTS 引擎：edge-tts（默认，微软 Azure 神经语音，需联网）| piper（本地 ONNX）
# SPEAKER_TTS_ENGINE=edge-tts
#
# Piper（树莓派推荐）：下载 Hugging Face rhasspy/piper-voices 下 zh/zh_CN/huayan 的 .onnx 与 .onnx.json
# 系统依赖：sudo apt install -y espeak-ng
# SPEAKER_TTS_ENGINE=piper
# SPEAKER_PIPER_MODEL=/path/to/zh_CN-huayan-medium.onnx
# SPEAKER_PIPER_CONFIG=              # 可选；默认使用「模型同目录的 .onnx.json」
# SPEAKER_PIPER_TIMEOUT_S=120        # 单句本地合成超时（秒）
# SPEAKER_PIPER_LENGTH_SCALE=        # 可选，如 1.1 略放慢
# SPEAKER_PIPER_CUDA=0               # 1 尝试 CUDA（树莓派上保持 0）
#
# SPEAKER_SOFTWARE_GAIN=2      # 软件增益倍数（>1.0 会 clip，USB 声卡偏小时补偿用）
# SPEAKER_PLAY_TIMEOUT_S=27    # 单句播放超时（秒）
# SPEAKER_TTS_TIMEOUT_S=15     # edge-tts 网络合成超时（秒）
#
# sense.audio.speak_end 兜底：播放链路异常时强制通知 Node；每播完一句且仍有队列时会重置计时
# AUDIO_SPEAK_END_FALLBACK_MS=45000
# AUDIO_SPEAK_END_IDLE_CONFIRM_MS=250

# ── 激光雷达 ──────────────────────────────────────────────────────
# 雷达安装偏移角（度）。LD06 线缆接口朝向机器人正前方时为 0（默认）。
# 如果雷达装反（线缆朝后），改为 180；线缆朝右改为 90。
LIDAR_MOUNT_ANGLE=0
# 雷达安装在车身最高处时建议开启：Explorer 使用更保守策略（降速、缩短脉冲、提前减速）。
# 注意这只能降低撞击风险，无法消除 2D 雷达对“低于扫描平面障碍物”的盲区。
# EXPLORER_HIGH_LIDAR=1
# 连续前进后位姿变化小于该阈值（mm）视为“无进展”，用于防止“走不动还走”。
# EXPLORER_PROGRESS_MIN_MOVE_MM=25
# 连续无进展前进脉冲达到该次数后，触发强制脱困（后退+大角度转向）。
# EXPLORER_STUCK_BURSTS=3
# Explorer 是否启用超声波前向安全门（默认启用，设 0 关闭）
# EXPLORER_USE_ULTRASONIC=1
# 超声波硬急停阈值（cm）：低于该值直接进入紧急避障（覆盖雷达前进判断）
# EXPLORER_ULTRASONIC_STOP_CM=25
# 超声波急停阈值安全下限（cm）：避免阈值过小导致来不及刹停
# EXPLORER_ULTRASONIC_STOP_MIN_CM=20
# 超声波谨慎阈值（cm）：低于该值优先转向，不执行前进脉冲
# EXPLORER_ULTRASONIC_TURN_CM=35
# 超声波读数最大可接受延迟（ms），过期读数视为不可用
# EXPLORER_ULTRASONIC_TTL_MS=350
# 前进分段安全门步长（秒）：每段前都会检查超声波，必要时立刻打断前进
# EXPLORER_FORWARD_GUARD_STEP_S=0.08
# 小空间转向参数：降低原地打转概率（方向正确但一直转不出来）
# EXPLORER_TURN_EXIT_MM=240
# EXPLORER_TURN_EXIT_DIAG_MM=330
# EXPLORER_TURN_SPEED=30
# EXPLORER_TURN_STEP_DURATION=0.4
# EXPLORER_MAX_TURN_STEPS=6
# EXPLORER_MAX_INPLACE_TURNS=4
# EXPLORER_INPLACE_POKE_DURATION=0.2
# EXPLORER_INPLACE_POKE_SPEED=22
# EXPLORER_TURN_HYSTERESIS_MM=120
# EXPLORER_DIAG_GUIDE_POKE_DURATION=0.22
# EXPLORER_DIAG_GUIDE_POKE_SPEED=24
# 是否允许后退动作（默认 0，策略偏“停+转+前进”）
# EXPLORER_ALLOW_REVERSE=0

# ── SearXNG 搜索引擎 ──────────────────────────────────────────────
# 本地 SearXNG Docker 容器地址（启动：docker compose up -d）
# 聚合 Bing / Google / DuckDuckGo / 百度等多个搜索引擎，供 searchWeb 工具使用
SEARXNG_URL=http://localhost:8080

# ── STT 语音转文字（typeless-sdk，/voice 语音页专用）────────────────
# 直接复用已有的 SPEECH_API_URL / SPEECH_API_KEY（Qwen ASR 风格网关）
# Qwen ASR 已自带断句和标点，不需要额外 LLM 润色。
#
# 可选：STT ASR 模型名（默认 qwen3-asr-flash）
# SPEECH_STT_MODEL=qwen3-asr-flash

# ── 服务配置 ──────────────────────────────────────────────────────
PORT=
LOG_LEVEL=info
# Turbopack + ws 在部分环境会触发 bufferUtil.mask 报错，设为 1 可强制使用 JS fallback
WS_NO_BUFFER_UTIL=1
