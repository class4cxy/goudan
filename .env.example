# ── 助手显示名 ────────────────────────────────────────────────────
# 对话人设兜底、唤醒词默认首项、聊天 UI、STT 润色词表、历史压缩中的助手角色名等。
# 省略时默认为「狗蛋」。
AGENT_DISPLAY_NAME=狗蛋

# ── 家庭住所信息（Bootstrap，供 Aria 了解住所布局）──────────────────
# 填写后重启生效（进程启动时读取一次并缓存）。
#
# ARIA_HOME_ROOMS     住所面积与房间列表（自然语言描述）
# ARIA_HOME_ROOM_NOTES 房间称呼歧义处理规则，多条用中文分号"；"分隔
#
# ARIA_HOME_ROOMS=共 110 平，11 个区域：入户、公共区、餐厅、厨房、客厅、阳台、主卧、儿童房、书房。
# ARIA_HOME_ROOM_NOTES=用户说"卫生间"时需询问是主卫还是次卫；用户说"卧室"时需询问具体是主卧、儿童房还是书房；用户说"阳台"默认指客厅连接的阳台；用户说"门口"或"玄关"默认指入户区域。

# ── 家庭成员信息（Bootstrap，供 Aria 了解家人）────────────────────
# 填写后重启生效（进程启动时读取一次并缓存）。
# 多条信息用中文分号"；"分隔，或直接用自然语言描述。
#
# ARIA_FAMILY_MEMBERS=主要用户：XXX（xx岁）；老人：XXX（xx岁，特点：xxx）；孩子：XXX（x岁）
# ARIA_FAMILY_HABITS=通常 xx 点起床，xx 点睡觉；常见口头表达：xxx
# ARIA_FAMILY_NOTES=（对 Aria 有特别提示的事项，如"老人听力偏弱，回答要简短清晰"）

# ── LLM ──────────────────────────────────────────────────────────
# 主模型（chat/task 等主链路）：DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key

# ── Roborock ──────────────────────────────────────────────────────
# 推荐：运行 `python platform/login_once.py` 完成一次性验证码登录
#       生成 platform/.roborock_token.json 后，Platform 启动不再需要密码
#
# 备用（次选）：密码登录（密码会以明文发到 Roborock 服务器，有日志记录风险）
ROBOROCK_USERNAME=your_xiaomi_email
# ROBOROCK_PASSWORD=your_xiaomi_password  ← 使用 token 文件后可删除此行

# Roborock 区域（cn=中国大陆，eu=欧洲，us=美国，默认 cn）
ROBOROCK_REGION=cn

# ── Platform 服务地址 ─────────────────────────────────────────────
# Platform HTTP 地址（REST API，默认本地；树莓派远程调试改为 http://192.168.x.x:8001）
PLATFORM_URL=http://localhost:8001

# Platform WebSocket 地址（实时事件双向通道）
PLATFORM_WS_URL=ws://localhost:8001/ws

# 语音对话是否必须唤醒词。调试链路时可设 false（免唤醒）
VOICE_REQUIRE_WAKE_WORD=true

# ── 本地唤醒词检测（openWakeWord，可选）────────────────────────────────────
# 填写后 Platform 启动时自动加载 OWW 模型，命中即发 sense.audio.keyword，
# 跳过 Whisper API，大幅减少 token 消耗和唤醒延迟（< 100ms vs 原 1-3s）。
#
# 可行性测试（先在树莓派上跑这个，确认硬件可用）：
#   cd platform && python devices/wake_word_test.py --list   # 列出内置模型
#   cd platform && python devices/wake_word_test.py --model hey_jarvis
#
# 内置预训练模型（英文，用于验证流程）：
#   hey_jarvis / alexa / hey_mycroft / hey_rhasspy / ok_nabu
#
# 自定义中文模型（训练后填写 .onnx 文件路径）：
#   WAKE_WORD_MODEL=/home/pi/models/gou_dan.onnx
#
# 空字符串 = 禁用 OWW，回退到原有 Whisper 文本匹配唤醒（默认）
WAKE_WORD_MODEL=
# WAKE_WORD_MODEL=hey_jarvis          # 英文测试
# WAKE_WORD_MODEL=/path/to/gou_dan.onnx  # 中文自定义模型

# OWW 检测阈值（0~1，越高越严格；默认 0.5）
# WAKE_WORD_THRESHOLD=0.5

# OWW 命中后冷却时长（秒，防止同一次说话重复触发；默认 1.5）
# WAKE_WORD_COOLDOWN_S=1.5

# 语音转文字配置
# 配置了本地就用本地，配置了远端就用远端，用不了直接报错（无自动降级）
#
# 【本地 STT】支持两种后端（LOCAL_STT_BACKEND 切换）
# LOCAL_STT_BACKEND=whisper     # 默认：faster-whisper，轻量开箱即用
# LOCAL_STT_BACKEND=qwen        # 备选：antirez/qwen-asr 纯 C，精度更高（需 8GB RAM）
#
# whisper 后端：pip install faster-whisper
# LOCAL_STT_MODEL=base          # tiny(39MB)/base(74MB)/small(244MB)
# LOCAL_STT_DEVICE=cpu
# LOCAL_STT_COMPUTE=int8
#
# qwen 后端：编译 antirez/qwen-asr + 下载模型
# LOCAL_STT_QWEN_BIN=~/qwen-asr/qwen_asr
# LOCAL_STT_QWEN_MODEL=~/qwen-asr/qwen3-asr-0.6b
#
# LOCAL_STT_URL=                # 显式指定本地 STT 端点（platform 已移除 /stt，默认用云端）
# STT_USE_CLOUD=1               # 设为 1 时强制使用云端 ASR

# 【云端 ASR】Qwen ASR（默认使用，需配置 SPEECH_API_URL / SPEECH_API_KEY）
SPEECH_API_URL=
SPEECH_API_KEY=

# 麦克风人声门控（Python 侧）
# MIC_MIN_VOICED_RATIO=0.35
# MIC_MIN_CLIP_RMS_DBFS=-42
# MIC_MUTE_TIMEOUT_S=25   # mute 超时（秒），超时强制 unmute 防止录音休眠
# MIC_MAX_SPEECH_MS=9000
# MIC_MIN_VOICE_BAND_RATIO=0.52
# MIC_MIN_ZCR=0.01
# MIC_MAX_ZCR=0.22

# ── 扬声器 / 蓝牙音频（Chat 模式）────────────────────────────────
#
# Chat 模式架构：手机端录音 → STT → 文字发给机器人 → TTS 回复通过蓝牙外放
# 不使用麦克风，无回声问题，录音全权交给手机处理。
#
# 播放后端选择：
#   alsa（默认）  — aplay，适合 USB 声卡直连
#   pulseaudio    — pacat，通过 PipeWire/PulseAudio A2DP 路由，蓝牙外放必须选此项
#
# 树莓派 5 蓝牙外放时，设置为 pulseaudio：
SPEAKER_BACKEND=pulseaudio
#
# 已连接蓝牙音响的 MAC 地址（供 connect_speaker.py 脚本读取，可省略手动输入）
# 首次使用先运行：python3 platform/connect_speaker.py --scan
# SPEAKER_MAC=AA:BB:CC:DD:EE:FF
#
# ALSA 后端专用：指定 aplay 输出设备（SPEAKER_BACKEND=alsa 时生效，默认 "default"）
# SPEAKER_ALSA_DEVICE=default
#
# TTS 引擎：edge-tts（默认，微软 Azure 神经语音，需联网）| piper（本地 ONNX）
# SPEAKER_TTS_ENGINE=edge-tts
#
# Piper（树莓派推荐）：下载 Hugging Face rhasspy/piper-voices 下 zh/zh_CN/huayan 的 .onnx 与 .onnx.json
# 系统依赖：sudo apt install -y espeak-ng
# SPEAKER_TTS_ENGINE=piper
# SPEAKER_PIPER_MODEL=/path/to/zh_CN-huayan-medium.onnx
# SPEAKER_PIPER_CONFIG=              # 可选；默认使用「模型同目录的 .onnx.json」
# SPEAKER_PIPER_TIMEOUT_S=120        # 单句本地合成超时（秒）
# SPEAKER_PIPER_LENGTH_SCALE=        # 可选，如 1.1 略放慢
# SPEAKER_PIPER_CUDA=0               # 1 尝试 CUDA（树莓派上保持 0）
#
# SPEAKER_SOFTWARE_GAIN=2      # 软件增益倍数（>1.0 会 clip，USB 声卡偏小时补偿用）
# SPEAKER_PLAY_TIMEOUT_S=27    # 播放等待下限（秒）；长句实际等待 max(本值, PCM估算时长+margin)
# SPEAKER_PLAY_TIMEOUT_MARGIN_S=8  # 在估算播放时长上追加的缓冲（蓝牙/重采样误差）
# SPEAKER_TTS_TIMEOUT_S=15     # edge-tts 网络合成超时（秒）
#
# sense.audio.speak_end 兜底：播放链路异常时强制通知 Node；每播完一句且仍有队列时会重置计时
# AUDIO_SPEAK_END_FALLBACK_MS=45000
# AUDIO_SPEAK_END_IDLE_CONFIRM_MS=250

# ── 编码器（GMR 1:90 编码电机，lgpio 驱动，支持树莓派 5）──────────────
# 安装 lgpio：sudo apt install -y python3-lgpio
# 树莓派 5 自动使用 gpiochip4（RP1），无需额外配置
# 接线：选后轮（左后/右后）的编码器 A/B 接树莓派 GPIO（BCM 编号，定稿见 docs/HARDWARE.md §7.1.1）
#   左后轮编码器（里程计）：A → GPIO12，B → GPIO11
#   右后轮编码器（里程计）：A → GPIO20，B → GPIO10
#   ⚠️ GPIO4  = 电源板 GP04 按钮，禁止用作编码器！
#   ⚠️ GPIO19 = 电源板 GP19 按钮，禁止用作编码器！
#   ⚠️ GPIO17 = 板载蜂鸣器，禁止用作编码器！
#   ⚠️ GPIO7/8 = spi0 CS，RPi5 内核强占，禁止使用！
#   ⚠️ GPIO13 = 舵机 Tilt，禁止使用！
# ENCODER_LEFT_A=12
# ENCODER_LEFT_B=11
# ENCODER_RIGHT_A=20
# ENCODER_RIGHT_B=21   # GPIO10=RGB灯SPI MOSI禁用，改用 GPIO21（Pin 40）
# ENCODER_LINES_PER_REV=500       # 编码器每圈线数（4倍频后 = 2000 ticks/rev）

# ── IMU（MPU6050 陀螺仪/加速度计，I2C）──────────────────────────────
# 接线：MPU6050 SDA → GPIO2，SCL → GPIO3，VCC → 3.3V，GND → GND，AD0 → GND
# 启用 I2C：sudo raspi-config → Interface Options → I2C → Enable
# 安装 smbus2：pip install smbus2
# IMU_I2C_ADDR=0x68               # AD0=GND 为 0x68；AD0=3.3V 为 0x69

# ── 里程计参数（需实测后填入）────────────────────────────────────────
# 关键参数：轮径 & 轮距影响定位精度，请用卡尺实测
# ODOM_WHEEL_RADIUS_MM=35.0       # 车轮半径（mm），实测值优先（7cm 轮径 = 35mm）
# ODOM_WHEEL_BASE_MM=160.0        # 两驱动轮中心距（mm），实测值优先
# ODOM_IMU_WEIGHT=0.3             # IMU 融合权重：0=纯编码器，1=纯IMU，0.3=推荐起始值
# ODOM_UPDATE_HZ=50               # 里程计更新频率

# ── AMCL 定位参数 ─────────────────────────────────────────────────────
# AMCL_N_PARTICLES=500            # 粒子数（越多越精但越慢，500 在 RPi5 够用）
# AMCL_ALPHA_XY_MM=30.0           # 运动模型噪声：位置标准差（mm）
# AMCL_ALPHA_TH_DEG=5.0           # 运动模型噪声：角度标准差（°）
# AMCL_SIGMA_HIT_MM=80.0          # 似然场传感器模型标准差（mm）
# AMCL_N_RAYS=36                  # 每帧使用的激光射线数（36 = 10° 间隔）
# AMCL_KIDNAP_THRESHOLD=0.02      # 绑架检测权重阈值（低于此值连续 N 帧触发全局重定位）
# AMCL_KIDNAP_FRAMES=10           # 连续低权重帧数触发绑架恢复
# AMCL_RECOVERY_RATIO=0.5         # 绑架恢复时随机散布的粒子比例
# AMCL_CONVERGE_XY_MM=200.0       # 粒子 x/y 标准差低于此值视为收敛

# ── 导航代价地图 ──────────────────────────────────────────────────────
# COSTMAP_ROBOT_RADIUS_MM=180.0   # 机器车半径（mm）用于障碍物膨胀
# COSTMAP_INFLATION_MM=60.0       # 安全余量（mm），机器人半径之外再留的缓冲
# COSTMAP_DYNAMIC_TTL_S=5.0       # 动态障碍消失后自动清除的时间（秒）

# ── DWA 局部规划参数 ──────────────────────────────────────────────────
# DWA_MAX_V_MM_S=300.0            # 最大线速度（mm/s）
# DWA_MIN_V_MM_S=0.0              # 最小线速度（不允许倒退）
# DWA_MAX_W_DEG_S=120.0           # 最大角速度（°/s）
# DWA_MAX_ACC_MM_S2=200.0         # 最大线加速度（mm/s²）
# DWA_MAX_ACC_W=90.0              # 最大角加速度（°/s²）
# DWA_PREDICT_TIME=1.5            # 轨迹预测时长（s）
# DWA_GOAL_TOL_MM=150.0           # 到达目标的距离容差（mm）

# ── 导航总协调器 ──────────────────────────────────────────────────────
# NAV_CONTROL_HZ=10.0             # 控制循环频率（Hz）
# NAV_REPLAN_EVERY_S=3.0          # A* 重规划周期（s）
# NAV_ARRIVED_TOL_MM=150.0        # 终点到达判定半径（mm）
# NAV_LOCALIZE_TIMEOUT=60.0       # AMCL 收敛等待超时（s）
# NAV_MAX_TIME_S=300.0            # 单次导航最大时长（s）

# ── 速度配置（语音/手动 与 室内建图 互不干扰）────────────────────────
# 语音/手动（navigateTo 工具）：Node 侧 MANUAL_DEFAULT_SPEED，默认 35
# MANUAL_DEFAULT_SPEED=35
# REST/直连底盘：Platform 侧 CHASSIS_DEFAULT_SPEED，默认 35
# CHASSIS_DEFAULT_SPEED=35
# 室内建图（Explorer）：EXPLORER_FORWARD_SPEED / EXPLORER_TURN_SPEED，与上面完全独立
# 若语音前进还是快，调低 MANUAL_DEFAULT_SPEED；若建图太慢，调高 EXPLORER_FORWARD_SPEED
# 转向时长（秒）：左转/右转约 85°，掉头约 175°，按角速度 ~100°/s 标定
# TURN_DEFAULT_DURATION=0.85
# TURN_AROUND_DURATION=1.75

# ── 激光雷达 ──────────────────────────────────────────────────────
# 雷达安装偏移角（度）。LD06 线缆接口朝向机器人正前方时为 0（默认）。
# 如果雷达装反（线缆朝后），改为 180；线缆朝右改为 90。
LIDAR_MOUNT_ANGLE=0
#
# 【激光雷达电机】
#
# 实测结论（RPi5，已验证）：LD06 电机由内部 PID 锁速 ~600 RPM，
# 无论外部 PWM 占空比如何变化（0%~100%，25kHz 硬件 PWM，万用表确认信号送达），
# 电机转速始终不变。PWM 引脚对电机无控制作用，悬空即可。
# lidar.stop() 仅关闭串口停止数据流，电机在通电期间持续旋转。
# 如需真正停止电机，须在 5V 供电线加装 P-MOSFET 断电电路（硬件改造）。
#
# LIDAR_MOTOR_PIN 配置已移除，不再需要。
# 雷达安装在车身最高处时建议开启：Explorer 使用更保守策略（降速、缩短脉冲、提前减速）。
# 注意这只能降低撞击风险，无法消除 2D 雷达对“低于扫描平面障碍物”的盲区。
# EXPLORER_HIGH_LIDAR=1
# 连续前进后位姿变化小于该阈值（mm）视为“无进展”，用于防止“走不动还走”。
# EXPLORER_PROGRESS_MIN_MOVE_MM=25
# 连续无进展前进脉冲达到该次数后，触发强制脱困（后退+大角度转向）。
# EXPLORER_STUCK_BURSTS=3
# Explorer 是否启用超声波前向安全门（默认启用，设 0 关闭）
# EXPLORER_USE_ULTRASONIC=1
# 超声波硬急停阈值（cm）：低于该值直接进入紧急避障（覆盖雷达前进判断）
# EXPLORER_ULTRASONIC_STOP_CM=25
# 超声波急停阈值安全下限（cm）：避免阈值过小导致来不及刹停
# EXPLORER_ULTRASONIC_STOP_MIN_CM=20
# 超声波谨慎阈值（cm）：低于该值优先转向，不执行前进脉冲
# EXPLORER_ULTRASONIC_TURN_CM=35
# 超声波读数最大可接受延迟（ms），过期读数视为不可用
# EXPLORER_ULTRASONIC_TTL_MS=350
# 前进分段安全门步长（秒）：每段前都会检查超声波，必要时立刻打断前进
# EXPLORER_FORWARD_GUARD_STEP_S=0.08
# 小空间转向参数：降低原地打转概率（方向正确但一直转不出来）
# EXPLORER_TURN_EXIT_MM=240
# EXPLORER_TURN_EXIT_DIAG_MM=330
# EXPLORER_FORWARD_SPEED=28        # 建图前进速度 0–100，默认 28，与 CHASSIS_DEFAULT_SPEED 独立
# EXPLORER_BURST_DURATION=0.5      # 脉冲前进时长（秒），默认 0.5
# EXPLORER_TURN_SPEED=30          # 建图转向速度 0–100
# EXPLORER_TURN_STEP_DURATION=0.55  # 建图单步转向时长（秒）
# EXPLORER_MAX_TURN_STEPS=6
# EXPLORER_MAX_INPLACE_TURNS=4
# EXPLORER_INPLACE_POKE_DURATION=0.2
# EXPLORER_INPLACE_POKE_SPEED=22
# EXPLORER_TURN_HYSTERESIS_MM=120
# EXPLORER_DIAG_GUIDE_POKE_DURATION=0.22
# EXPLORER_DIAG_GUIDE_POKE_SPEED=24
# 是否允许后退动作（默认 0，策略偏“停+转+前进”）
# EXPLORER_ALLOW_REVERSE=0
# 建图调试日志：1=每轮决策写入 logs/explorer_*.jsonl，便于分析乱转/斜顶等问题
# EXPLORER_LOG_DATA=1
# 建图调试：控制台输出结构化决策日志
# EXPLORER_LOG_VERBOSE=1
# Platform 调试：记录 lidar/slam/ultrasonic 请求响应摘要（需在 Platform 进程设置）
# EXPLORER_DEBUG_LOG=1

# ── SLAM 建图参数（Platform 进程）────────────────────────────────────
# 方案1 已生效：地图 1000×1000 像素 / 20m×20m，max_search_iter=1500
# SLAM_MAP_SIZE_PIXELS=1000   # 地图分辨率，增大可减轻轮廓消失
# SLAM_MAP_SIZE_METERS=20     # 物理范围（米）
# SLAM_MAX_SEARCH_ITER=1500   # RMHC 搜索迭代上限（默认 1000），提高增强定位稳定性
# SLAM_MAP_QUALITY=50         # 地图更新强度；轮廓消失可试 35–40
# SLAM_SIGMA_XY_MM=100       # 位姿不确定度；可试 70
# SLAM_SIGMA_THETA_DEG=20    # 角度不确定度；可试 15

# ── SearXNG 搜索引擎 ──────────────────────────────────────────────
# 本地 SearXNG Docker 容器地址（启动：docker compose up -d）
# 聚合 Bing / Google / DuckDuckGo / 百度等多个搜索引擎，供 searchWeb 工具使用
SEARXNG_URL=http://localhost:8080

# ── STT 语音转文字（typeless-sdk，/voice 语音页专用）────────────────
# 直接复用已有的 SPEECH_API_URL / SPEECH_API_KEY（Qwen ASR 风格网关）
# Qwen ASR 已自带断句和标点，不需要额外 LLM 润色。
#
# 可选：STT ASR 模型名（默认 qwen3-asr-flash）
# SPEECH_STT_MODEL=qwen3-asr-flash

# ── 服务配置 ──────────────────────────────────────────────────────
PORT=
LOG_LEVEL=info
# Turbopack + ws 在部分环境会触发 bufferUtil.mask 报错，设为 1 可强制使用 JS fallback
WS_NO_BUFFER_UTIL=1
