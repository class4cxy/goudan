# 环境变量（含密钥）
.env

# Roborock token 缓存（含登录态，不能泄露）
platform/.roborock_token.json

# 数据库
data/
docs/

# 临时截图
/tmp/home-agent-snapshots/

# Python
platform/.venv/
__pycache__/
*.pyc

# Node.js
node_modules/
dist/

.next

# 系统文件
.DS_Store

# lg GPIO 库运行时创建的 FIFO 管道（树莓派等）
.lgd-nfy*

# HTTPS 本地证书（mkcert 生成，不提交）
certs/

# Explorer 建图调试日志（EXPLORER_LOG_DATA=1 生成）
logs/
